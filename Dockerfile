# Используем стабильную версию ноды
FROM node:18-alpine

# Устанавливаем git и зависимости для сборки (если пригодятся)
RUN apk add --no-cache git

# Создаем рабочую директорию
WORKDIR /app

# Сначала копируем только конфиги пакетов (для кэширования слоев)
COPY package*.json ./

# Устанавливаем зависимости (чистая установка для продакшена)
RUN npm ci --omit=dev

# Копируем все остальные файлы проекта
COPY . .

# Создаем папку для базы данных и выставляем права пользователю 'node'
# Это КРИТИЧНО для сохранения данных в json
RUN mkdir -p /app/data && chown -R node:node /app

# Переключаемся на безопасного пользователя
USER node

# Открываем порт
EXPOSE 3000

# Запускаем основной файл
CMD ["node", "server.js"]
