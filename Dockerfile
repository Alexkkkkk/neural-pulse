# Используем полную версию node для гарантии наличия всех инструментов сборки
FROM node:18

# Устанавливаем рабочую директорию
WORKDIR /app

# Сначала копируем только файлы зависимостей (для кэширования слоев Docker)
COPY package*.json ./

# Устанавливаем зависимости
# Используем --include=dev если тебе нужны инструменты сборки в runtime, 
# но для Bothost достаточно обычной установки
RUN npm install

# Копируем все остальные файлы проекта (server.js, dashboard.jsx, static и т.д.)
COPY . .

# Открываем порт, который указан в твоем server.js
EXPOSE 3000

# Запускаем через node напрямую (это быстрее и надежнее в Docker, чем npm start)
CMD ["node", "server.js"]
