# Используем максимально легкий образ
FROM node:18-alpine

# Устанавливаем git (критично для сборки некоторых модулей)
RUN apk add --no-cache git

# Рабочая директория
WORKDIR /app

# Копируем файлы манифеста
COPY package*.json ./

# Установка зависимостей без лишнего мусора (логи, аудиты)
# Это ускоряет запуск контейнера на Bothost
RUN npm install --omit=dev --no-audit --no-fund

# Копируем исходный код
COPY . .

# Подготовка хранилища данных
# Права 777 нужны, так как Bothost часто меняет ID пользователя в рантайме
RUN mkdir -p /app/data && chmod -R 777 /app/data

# Сообщаем системе о порте
EXPOSE 3000

# Запуск напрямую через node для мгновенного старта
# Это позволит server.js сразу начать установку вебхука
CMD ["node", "server.js"]
