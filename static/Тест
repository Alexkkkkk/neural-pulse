<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Neural Pulse AI</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root { 
            --neon: #00d4ff; 
            --neon-secondary: #00ff96; 
            --bg: #050a1a; 
            --glass: rgba(10, 25, 47, 0.95);
        }

        @keyframes rainbow-pulse {
            0% { filter: hue-rotate(0deg); }
            100% { filter: hue-rotate(360deg); }
        }

        body { 
            margin: 0; background: radial-gradient(circle at center, #0a192f 0%, #050a1a 100%); 
            height: 100vh; font-family: 'Orbitron', sans-serif; color: white; overflow: hidden; 
            user-select: none; display: flex; justify-content: center; 
        }

        .game-container { position: relative; width: 100%; max-width: 500px; height: 100vh; display: flex; flex-direction: column; align-items: center; padding: 20px; box-sizing: border-box; }
        
        /* Лого с радугой */
        .logo { width: 50px; height: 50px; background: url('/static/images/unnamed4.png') no-repeat center/cover; border-radius: 12px; box-shadow: 0 0 15px var(--neon); animation: rainbow-pulse 5s linear infinite; }
        
        .header { width: 100%; display: flex; justify-content: space-between; align-items: center; margin-top: 10px; }
        #score { font-size: 42px; text-shadow: 0 0 20px var(--neon); font-weight: bold; margin-top: 10px; }
        
        .play-area { position: relative; flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
        
        /* Главная кнопка */
        #btn { 
            width: 65vw; height: 65vw; max-width: 250px; max-height: 250px;
            background: url('/static/images/unnamed3.png') no-repeat center/contain;
            border-radius: 50%; border: none; cursor: pointer; outline: none;
            box-shadow: 0 0 30px var(--neon); transition: transform 0.05s;
        }
        #btn:active { transform: scale(0.95); }

        /* Энергия */
        .energy-wrapper { width: 80%; margin-top: 20px; }
        .energy-info { display: flex; justify-content: space-between; font-size: 12px; color: var(--neon); margin-bottom: 5px; }
        .energy-bar { width: 100%; height: 10px; background: rgba(255,255,255,0.1); border-radius: 5px; border: 1px solid var(--neon); overflow: hidden; }
        #energy-fill { height: 100%; width: 100%; background: var(--neon); transition: width 0.3s; }

        .side-menu { position: absolute; right: 0; display: flex; flex-direction: column; gap: 10px; }
        .side-btn { width: 80px; padding: 8px; background: rgba(255,255,255,0.05); border: 1px solid var(--neon); border-radius: 8px; font-size: 10px; color: white; text-align: center; }

        .bottom-nav { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; margin-bottom: 20px; }
        .nav-item { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 12px; text-align: center; font-size: 12px; border: 1px solid rgba(255,255,255,0.1); }

        /* Модалки */
        .modal { position: fixed; bottom: -100%; left: 0; width: 100%; height: 70%; background: var(--glass); border-top: 2px solid var(--neon); border-radius: 25px 25px 0 0; z-index: 1000; transition: 0.4s; padding: 25px; box-sizing: border-box; }
        .modal.active { bottom: 0; }
        .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: none; z-index: 999; }
        .overlay.active { display: block; }
        
        .stat-box { background: rgba(255,255,255,0.05); padding: 15px; border-radius: 10px; margin-bottom: 10px; border: 1px solid rgba(0,212,255,0.2); }
        .buy-btn { width: 100%; padding: 12px; background: var(--neon); color: black; border: none; border-radius: 8px; font-weight: bold; margin-top: 5px; }

        .plus-animation { position: absolute; color: var(--neon); font-size: 28px; font-weight: bold; animation: float 0.7s ease-out forwards; pointer-events: none; }
        @keyframes float { 0% { opacity: 1; transform: translateY(0); } 100% { opacity: 0; transform: translateY(-100px); } }
    </style>
</head>
<body>
    <div class="game-container">
        <div class="header">
            <div class="logo"></div>
            <div id="lvl">🏆 Новичок</div>
        </div>

        <div id="score">0</div>

        <div class="play-area">
            <div class="side-menu">
                <div class="side-btn" onclick="openModal('friends')">Friends</div>
                <div class="side-btn" onclick="openModal('tasks')">Tasks</div>
            </div>
            
            <button id="btn"></button>

            <div class="energy-wrapper">
                <div class="energy-info">
                    <span>⚡ Энергия</span>
                    <span id="energy-stat">1000/1000</span>
                </div>
                <div class="energy-bar"><div id="energy-fill"></div></div>
            </div>
        </div>

        <div class="bottom-nav">
            <div class="nav-item" onclick="openModal('boost')">🚀 BOOST</div>
            <div class="nav-item" onclick="openModal('mine')">⛏️ MINE</div>
            <div class="nav-item" onclick="openModal('stats')">📊 STATS</div>
        </div>
    </div>

    <div class="overlay" id="overlay" onclick="closeModals()"></div>

    <div id="modal-boost" class="modal">
        <h2>Улучшения</h2>
        <div class="stat-box">
            <div>Multi-Tap (Сила клика)</div>
            <button class="buy-btn" onclick="buyUpgrade('tap')">Улучшить</button>
        </div>
        <div class="stat-box">
            <div>Energy Limit (Макс. энергия)</div>
            <button class="buy-btn" onclick="buyUpgrade('energy')">Улучшить</button>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        let score = 0;
        let energy = 1000;
        let maxEnergy = 1000;
        let tapPower = 1;

        function updateUI() {
            document.getElementById('score').textContent = Math.floor(score).toLocaleString();
            document.getElementById('energy-stat').textContent = `${Math.floor(energy)}/${maxEnergy}`;
            document.getElementById('energy-fill').style.width = (energy / maxEnergy * 100) + '%';
        }

        document.getElementById('btn').addEventListener('touchstart', (e) => {
            e.preventDefault();
            if (energy >= tapPower) {
                energy -= tapPower;
                score += tapPower;
                spawnPlus(e.touches[0].pageX, e.touches[0].pageY);
                updateUI();
                tg.HapticFeedback.impactOccurred('medium');
            }
        });

        function spawnPlus(x, y) {
            const p = document.createElement('div');
            p.className = 'plus-animation';
            p.style.left = x + 'px'; p.style.top = y + 'px';
            p.textContent = `+${tapPower}`;
            document.body.appendChild(p);
            setTimeout(() => p.remove(), 700);
        }

        // Реген энергии: +1 в секунду
        setInterval(() => {
            if (energy < maxEnergy) {
                energy = Math.min(maxEnergy, energy + 1);
                updateUI();
            }
        }, 1000);

        function openModal(id) {
            document.getElementById('overlay').classList.add('active');
            document.getElementById('modal-' + id).classList.add('active');
        }

        function closeModals() {
            document.getElementById('overlay').classList.remove('active');
            document.querySelectorAll('.modal').forEach(m => m.classList.remove('active'));
        }

        async function buyUpgrade(type) {
            // Тут должен быть fetch к твоему API
            tg.showAlert("Улучшение куплено (визуально)");
            if(type === 'energy') maxEnergy += 500;
            if(type === 'tap') tapPower += 1;
            updateUI();
        }

        tg.expand();
        updateUI();
    </script>
</body>
</html>
