# Используем стабильную версию Node.js (slim для экономии ресурсов)
FROM node:20-slim

# Устанавливаем системные зависимости, необходимые для сборки некоторых 
# библиотек (например, для взаимодействия с БД и компиляции фронтенда AdminJS)
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

# Создаем рабочую директорию внутри контейнера
WORKDIR /app

# Копируем только файлы манифеста зависимостей для кэширования слоев Docker
COPY package*.json ./

# Устанавливаем зависимости. 
# Мы оставляем dev-зависимости, так как AdminJS использует их для сборки (bundling) UI
RUN npm install && npm cache clean --force

# Копируем весь исходный код, папку static, дизайн и картинки
COPY . .

# Создаем папку для кэша AdminJS и даем права (важно для облачных хостингов)
RUN mkdir -p .adminjs && chmod -R 777 .adminjs

# Открываем порты:
# 3000 — основной порт (API, Бот и Прокси)
# 3001 — порт админ-панели (внутренний)
EXPOSE 3000
EXPOSE 3001

# ВАЖНО: Команда запуска изменена на server.js. 
# Это твой диспетчер, который поднимает и Бота, и Админку одновременно.
CMD ["node", "server.js"]
