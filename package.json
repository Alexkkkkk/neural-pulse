{
  "name": "neural-pulse",
  "version": "1.2.0",
  "type": "module",
  "main": "server.js",
  "engines": {
    "node": ">=18.16.0"
  },
  "scripts": {
    "start": "node --expose-gc --max-old-space-size=1024 --optimize-for-size --gc-interval=100 --turbo-fast-api-calls server.js",
    "dev": "node --watch server.js",
    "install-all": "npm install",
    "clean": "rm -rf node_modules package-lock.json && npm install --production=false",
    "rebuild": "npm run clean && npm start",
    "lint": "echo \"System Scan... OK\""
  },
  "dependencies": {
    "adminjs": "^7.8.1",
    "@adminjs/express": "^6.1.0",
    "@adminjs/sequelize": "^4.0.0",
    "@adminjs/design-system": "^4.1.0",
    "express": "^4.18.2",
    "telegraf": "^4.16.3",
    "sequelize": "^6.37.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "moment-timezone": "^0.5.45",
    "express-session": "^1.18.0",
    "connect-session-sequelize": "^7.1.7",
    "express-formidable": "^1.2.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "axios": "^1.6.7",
    "fast-json-stringify": "^5.12.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "@tonconnect/ui-react": "^2.0.9",
    "@ton/ton": "^13.9.0",
    "@ton/crypto": "^3.2.0",
    "styled-components": "^6.1.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tslib": "^2.6.2",
    "framer-motion": "^11.0.8",
    "babel-plugin-transform-react-remove-prop-types": "^0.4.24",
    "babel-plugin-styled-components": "^2.1.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3"
  },
  "description": "Neural Pulse OS - Ultra Fast Performance Edition"
}
