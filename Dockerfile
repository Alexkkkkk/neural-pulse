# Используем стабильную версию ноды
FROM node:18-alpine

# Устанавливаем git (необходим для некоторых npm пакетов)
RUN apk add --no-cache git

# Создаем рабочую директорию
WORKDIR /app

# Копируем конфиги пакетов для кэширования слоев
COPY package*.json ./

# Устанавливаем зависимости (продакшн версия)
RUN npm install --omit=dev

# Копируем все файлы проекта
COPY . .

# Создаем папку для базы данных и даем ПОЛНЫЕ права.
# Это важно, так как мы не знаем, под каким пользователем BotHost запустит процесс.
RUN mkdir -p /app/data && chmod 777 /app/data

# Открываем порт 3000 (внутренний стандарт BotHost)
EXPOSE 3000

# Финальный запуск.
# Используем конструкцию, которая сначала пробует запустить твой сервер напрямую.
CMD ["node", "server.js"]
