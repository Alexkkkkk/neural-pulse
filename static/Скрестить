    <script>

        const tg = window.Telegram.WebApp;

        tg.expand();

        

        // Telegram Data

        const userId = tg.initDataUnsafe?.user?.id || 12345678;

        document.getElementById('user-id-display').textContent = "ID: " + userId;

        document.getElementById('modal-user-id').textContent = userId;



        // Game State

        let score = 0, clickPower = 1, energy = 1000, maxEnergy = 1000;



        function updateUI() {

            document.getElementById('score').textContent = Math.floor(score).toLocaleString();

            document.getElementById('energy-val').textContent = `${Math.floor(energy)} / ${maxEnergy}`;

            document.getElementById('energy-fill').style.width = (energy / maxEnergy * 100) + '%';

            document.getElementById('energy-limit-val').textContent = maxEnergy;

            document.getElementById('boost-power-val').textContent = clickPower;

        }



        async function syncWithServer() {

            try {

                await fetch('/api/clicks', {

                    method: 'POST',

                    headers: {'Content-Type': 'application/json'},

                    body: JSON.stringify({ user_id: userId, amount: clickPower })

                });

            } catch (e) { console.error("Sync error", e); }

        }



        document.getElementById('btn').addEventListener('touchstart', (e) => {

            e.preventDefault();

            if (energy >= clickPower) {

                energy -= clickPower;

                score += clickPower;

                const t = e.changedTouches[0];

                spawnPlus(t.pageX, t.pageY, clickPower);

                updateUI();

                syncWithServer();

                tg.HapticFeedback?.impactOccurred('light');

            } else {

                tg.HapticFeedback?.notificationOccurred('error');

            }

        });



        function spawnPlus(x, y, val) {

            const p = document.createElement('div');

            p.className = 'plus-animation';

            p.textContent = '+' + val;

            p.style.left = (x - 20) + 'px'; p.style.top = (y - 40) + 'px';

            document.body.appendChild(p);

            setTimeout(() => p.remove(), 700);

        }



        setInterval(() => {

            if (energy < maxEnergy) {

                energy = Math.min(maxEnergy, energy + 1);

                updateUI();

            }

        }, 1000);



        function handleUpgrade(type) {

            if (score >= 500) {

                score -= 500;

                if (type === 'tap') clickPower += 1;

                if (type === 'energy') maxEnergy += 500;

                updateUI();

                tg.HapticFeedback?.notificationOccurred('success');

            } else {

                tg.showAlert("Недостаточно NP!");

            }

        }



        // Leaderboard Logic

        function loadLeaderboard() {

            const list = document.getElementById('leaderboard-list');

            list.innerHTML = '';



            // Список из 20 игроков (Твой счет всегда актуален)

            const players = [

                { id: userId, score: score, name: "Вы (You)" },

                { id: 10001, score: 2500000, name: "NeuralMaster" },

                { id: 10002, score: 1850400, name: "CyberPulse" },

                { id: 10003, score: 980200, name: "Admin_Top" },

                { id: 10004, score: 750000, name: "Satoshi_N" },

                { id: 10005, score: 500100, name: "ClickerGod" },

                { id: 10006, score: 420000, name: "AI_Hunter" },

                { id: 10007, score: 310000, name: "Flash_Dev" },

                { id: 10008, score: 290000, name: "CryptoKing" },

                { id: 10009, score: 150000, name: "User_88" },

                { id: 10010, score: 120000, name: "BetaTester" },

                { id: 10011, score: 95000, name: "Giga_Click" },

                { id: 10012, score: 84000, name: "Z-Pulse" },

                { id: 10013, score: 72000, name: "Shadow" },

                { id: 10014, score: 55000, name: "Matrix" },

                { id: 10015, score: 43000, name: "Noob_1" },

                { id: 10016, score: 32000, name: "FastTap" },

                { id: 10017, score: 15000, name: "Newbie" },

                { id: 10018, score: 8000, name: "Zero_X" },

                { id: 10019, score: 5000, name: "PulseUser" }

            ];



            players.sort((a, b) => b.score - a.score);



            players.forEach((player, index) => {

                const item = document.createElement('div');

                item.className = `leader-item ${player.id === userId ? 'my-rank' : ''}`;

                item.innerHTML = `

                    <span class="leader-rank">#${index + 1}</span>

                    <span class="leader-name">${player.name}</span>

                    <span class="leader-score">${Math.floor(player.score).toLocaleString()} NP</span>

                `;

                list.appendChild(item);

            });

        }



        // Modals

        function openModal(id) {

            if(id === 'stats') loadLeaderboard();

            document.getElementById('overlay').classList.add('active');

            document.getElementById('modal-' + id).classList.add('active');

        }



        function closeAllModals() {

            document.getElementById('overlay').classList.remove('active');

            document.querySelectorAll('.modal').forEach(m => m.classList.remove('active'));

        }



        window.onload = () => {

            updateUI();

            document.getElementById('game').style.opacity = '1';

        };

    </script>

