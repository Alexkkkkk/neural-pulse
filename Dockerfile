# Используем стабильную и легкую версию Node.js
FROM node:18-alpine

# Устанавливаем git (нужен, если в package.json есть ссылки на GitHub-репозитории)
RUN apk add --no-cache git

# Создаем рабочую директорию
WORKDIR /app

# Копируем конфиги пакетов. Сначала только их, чтобы не переустанавливать модули при каждом изменении кода.
COPY package*.json ./

# Устанавливаем только необходимые зависимости для работы (без тестов и линтеров)
RUN npm install --omit=dev --no-audit --no-fund

# Копируем абсолютно все файлы проекта (включая папку static и server.js)
COPY . .

# Создаем папку для базы данных JSON. 
# chmod 777 гарантирует, что база сможет записаться, даже если Bothost запустит бота под другим пользователем.
RUN mkdir -p /app/data && chmod 777 /app/data

# Открываем порт 3000 — это "золотой стандарт" для Bothost
EXPOSE 3000

# Запускаем сервер. 
# Мы не используем npm start, чтобы избежать лишних прослоек и быстрее реагировать на ошибки.
CMD ["node", "server.js"]
