        /* SCORE */

        .balance-container { text-align: center; margin-top: 20px; }

        #score { font-size: 48px; color: #fff; text-shadow: 0 0 20px var(--neon); font-weight: bold; }

        

        /* PLAY AREA */

        .play-area { position: relative; flex-grow: 1; width: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; }

        #btn { 

            width: 65vw; max-width: 260px; height: 65vw; max-height: 260px; 

            background: url('/static/images/unnamed3.png') no-repeat center; 

            background-size: contain; border-radius: 50%; border: none; 

            cursor: pointer; transition: transform 0.05s, box-shadow 0.2s; 

            outline: none; z-index: 2;

            box-shadow: 0 0 30px var(--neon);

        }

        #btn:active { transform: scale(0.92); }



        .side-menu { position: absolute; right: 0; display: flex; flex-direction: column; gap: 12px; z-index: 3; }

        .side-item { width: 85px; padding: 10px 5px; background: rgba(255,255,255,0.05); border: 1px solid rgba(0, 212, 255, 0.4); border-radius: 8px; backdrop-filter: blur(5px); font-size: 9px; text-align: center; cursor: pointer; transition: 0.3s; color: white; }



        /* ENERGY */

        .energy-container { width: 100%; max-width: 280px; margin-top: 25px; }

        .energy-text { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 5px; color: var(--neon); }

        .energy-bar-bg { width: 100%; height: 12px; background: rgba(255,255,255,0.1); border-radius: 10px; overflow: hidden; border: 1px solid rgba(0, 212, 255, 0.3); }

        #energy-fill { width: 100%; height: 100%; background: linear-gradient(90deg, var(--neon), var(--neon-secondary)); transition: width 0.2s; }

        

        /* NAVIGATION */

        .bottom-nav { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; width: 100%; margin-bottom: 20px; }

        .nav-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 15px 5px; text-align: center; font-size: 10px; cursor: pointer; }

        

        /* MODALS */

        .overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: none; z-index: 999; backdrop-filter: blur(4px); }

        .overlay.active { display: block; }

        .modal { position: fixed; bottom: -100%; left: 0; width: 100%; height: 75%; background: var(--glass); border-top: 2px solid var(--neon); border-radius: 30px 30px 0 0; z-index: 1000; transition: bottom 0.4s cubic-bezier(0.4, 0, 0.2, 1); padding: 30px; box-sizing: border-box; overflow-y: auto; }

        .modal.active { bottom: 0; }

        .close-btn { font-size: 28px; color: var(--neon); cursor: pointer; float: right; }

        

        .stat-box { background: rgba(255,255,255,0.03); padding: 15px; border-radius: 12px; margin-bottom: 10px; text-align: center; border: 1px solid rgba(255,255,255,0.1); }

        .btn-action { width:100%; padding:15px; background:var(--neon); border:none; border-radius:10px; color:#000; font-weight:bold; cursor:pointer; font-family:'Orbitron'; margin-top: 10px; }



        /* LEADERBOARD */

        .leaderboard { margin-top: 20px; text-align: left; background: rgba(255, 255, 255, 0.02); border-radius: 15px; padding: 10px; border: 1px solid rgba(0, 212, 255, 0.1); }

        .leader-item { display: flex; justify-content: space-between; padding: 8px 12px; border-bottom: 1px solid rgba(255, 255, 255, 0.05); font-size: 12px; align-items: center; }

        .leader-item:last-child { border: none; }

        .leader-rank { color: var(--neon); font-weight: bold; width: 30px; }

        .leader-name { flex-grow: 1; opacity: 0.9; }

        .leader-score { color: var(--neon-secondary); font-family: monospace; }

        .my-rank { background: rgba(0, 212, 255, 0.15); border-radius: 8px; border: 1px solid var(--neon); }



        /* ANIMATIONS */

        .plus-animation { position: absolute; color: var(--neon); font-size: 32px; font-weight: bold; animation: float 0.7s ease-out forwards; pointer-events: none; z-index: 100; text-shadow: 0 0 15px var(--neon); }

        @keyframes float { 0% { opacity:1; transform: translateY(0) scale(1); } 100% { opacity:0; transform: translateY(-120px) scale(1.5); } }

    </style>

</head>

