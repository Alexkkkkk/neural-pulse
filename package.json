
{
  "name": "neural-pulse",
  "version": "1.1.0",
  "description": "Neural Pulse Telegram WebApp Game - High Performance Core",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "npm run rebuild",
    "prod": "pm2-runtime start ecosystem.config.js --env production",
    "stop": "pm2 stop neural-pulse-core",
    "restart": "pm2 restart neural-pulse-core",
    "reload": "pm2 reload neural-pulse-core",
    "logs": "pm2 logs neural-pulse-core",
    "monit": "pm2 monit",
    "rebuild": "npm rebuild sqlite3 --build-from-source",
    "db:vacuum": "sqlite3 data/game.db 'VACUUM;'"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "sqlite3": "^5.1.7",
    "sqlite": "^5.1.1",
    "telegraf": "^4.16.3",
    "cors": "^2.8.5",
    "winston": "^3.11.0",
    "pm2": "^5.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Alexkkkkk",
  "license": "ISC"
}
